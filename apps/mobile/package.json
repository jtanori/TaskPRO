{
  "name": "@taskpro/mobile",
  "version": "0.0.0",
  "private": true,
  "description": "TaskPRO Expo React Native mobile application",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "build": "echo 'Mobile build configured in later expedition'",
    "build:local": "node -e \"require('fs').mkdirSync('../../dist',{recursive:true})\" && eas build --platform android --profile preview --local --non-interactive --output ../../dist/taskpro-local.apk",
    "build:staging": "node -e \"require('fs').mkdirSync('../../dist',{recursive:true})\" && eas build --platform android --profile staging --local --non-interactive --output ../../dist/taskpro-staging.apk",
    "build:production": "node -e \"require('fs').mkdirSync('../../dist',{recursive:true})\" && eas build --platform android --profile production --local --non-interactive --output ../../dist/taskpro-production.aab",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@taskpro/design-tokens": "workspace:*",
    "@taskpro/domain": "workspace:*",
    "@taskpro/types": "workspace:*",
    "@taskpro/ui": "workspace:*",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.0",
    "expo-linking": "~7.0.0",
    "expo-localization": "~7.0.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "i18next": "^24.2.0",
    "react": "^18.3.1",
    "react-i18next": "^15.4.0",
    "react-native-url-polyfill": "^2.0.0",
    "@supabase/supabase-js": "^2.47.10",
    "react-native": "^0.76.5",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-safe-area-context": "^4.14.1",
    "react-native-screens": "~4.0.0"
  },
  "devDependencies": {
    "@taskpro/config": "workspace:*",
    "@taskpro/eslint": "workspace:*",
    "@types/react": "^18.3.12",
    "eas-cli": "^12.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
