# TaskPRO environment variables
# Copy to .env.local for development and fill in real values.
# Never commit files containing secrets.

# Application environment: development | local | staging | production
EXPO_PUBLIC_APP_ENV=development

# Backend API base URL (optional for development/local)
EXPO_PUBLIC_API_URL=https://api.taskpro.example

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Analytics and crash reporting
EXPO_PUBLIC_POSTHOG_API_KEY=your-posthog-key
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn

# Maps (optional)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-key

# Payments
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
